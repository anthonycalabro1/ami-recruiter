# ============================================================
# Streamlit Cloud Secrets Template
# ============================================================
# 1. Copy the contents of THIS file into Streamlit Cloud:
#    Your app → Settings → Secrets → paste below
# 2. Fill in your real values (do NOT commit the real secrets file)
# ============================================================

# PostgreSQL connection string from Supabase
# Supabase project → Settings → Database → Connection string → URI
DATABASE_URL = "postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Anthropic API key (dashboard uses this for rubric feedback display only)
ANTHROPIC_API_KEY = "sk-ant-api03-your-key-here"

# Gmail notification settings
GMAIL_ADDRESS        = "your-email@gmail.com"
GMAIL_APP_PASSWORD   = "your-16-char-app-password"
NOTIFICATION_EMAIL   = "your-email@gmail.com"
